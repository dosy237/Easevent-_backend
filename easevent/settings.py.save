# Toutes les valeurs sensibles viennent du fichier .env
DATABASES = {
    'default': {
        'ENGINE':   'django.db.backends.postgresql',
        'NAME':     config('DB_NAME',     default='easevent_db'),
        'USER':     config('DB_USER',     default='easevent_user'),
